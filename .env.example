# Publiczny adres strony (bez ukośnika na końcu). Domena docelowa.
# Czytany przez metadata, Open Graph, JSON-LD, sitemap.xml i robots.txt.
NEXT_PUBLIC_SITE_URL=https://rajreal.pl

# --- Wysyłka maili z formularza kontaktowego (Resend) ---
# https://resend.com — klucz API projektu
RESEND_API_KEY=re_xxxxxxxxxxxxxxxxxxxxxxxxxx
# Adres nadawcy zweryfikowany w Resend (domena musi być zweryfikowana)
CONTACT_FROM_EMAIL=formularz@rajreal.pl
# Adres właściciela firmy, na który trafiają leady
CONTACT_TO_EMAIL=kontakt@rajreal.pl

# Alternatywnie: wysyłka przez SMTP zamiast Resend (ustaw CONTACT_PROVIDER=smtp)
CONTACT_PROVIDER=resend
SMTP_HOST=
SMTP_PORT=587
SMTP_USER=
SMTP_PASSWORD=
